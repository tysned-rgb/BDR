# Alta Voice BDR Agent - Environment Variables
# Copy this file to .env and fill in all values

# Vapi
VAPI_API_KEY=your-vapi-private-key

# HubSpot
HUBSPOT_API_KEY=your-hubspot-private-app-token

# HubSpot List ID (find this in HubSpot: Lists > click your list > the number in the URL)
# e.g. https://app.hubspot.com/contacts/XXXXXXX/lists/12345 → 12345
HUBSPOT_LIST_ID=

# HubSpot Meetings / Demo Booking URL
DEMO_BOOKING_URL=https://meetings.hubspot.com/altavoice/demo

# Outbound Phone Number (as configured in Vapi)
OUTBOUND_PHONE_NUMBER=+13852357065

# Vapi Phone Number ID (get this after importing your number into Vapi)
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id

# Vapi Assistant ID (populated automatically by setup.js)
VAPI_ASSISTANT_ID=

# Your webhook server's public URL (e.g. from Railway, Render, or ngrok for local dev)
SERVER_URL=

# Port for local server
PORT=3000
